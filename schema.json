{
  "name": "dataproducts",
  "displayName": "dataproducts",
  "version": "0.0.33",
  "language": {
    "csharp": {
      "respectSchemaVersion": true
    },
    "go": {
      "respectSchemaVersion": true
    },
    "java": {
      "respectSchemaVersion": true
    },
    "nodejs": {
      "respectSchemaVersion": true
    },
    "python": {
      "respectSchemaVersion": true
    }
  },
  "config": {},
  "provider": {},
  "resources": {
    "dataproducts:index:DataProductWithAspects": {
      "description": "Custom Pulumi component that creates a Dataplex data product with:\n    - Mandatory standardized aspects (business, compliance, technical)\n    - Optional data asset attachment (BigQuery, GCS)\n    - Optional data quality scans\n    - Optional monitoring and alerting\n    - Optional cost tracking\n    - Optional version management\n    - Optional lineage tracking\n    - Optional automated access requests\n\n    Prerequisites:\n    - Google Groups specified in access_groups must already exist\n    - Service accounts must have dataplex.dataProducts.requestAccess permission\n    - Aspect types must be created in Dataplex before using this component",
      "properties": {
        "aspectsApplied": {
          "type": "integer",
          "description": "Number of aspects applied to the data product"
        },
        "dataProductId": {
          "type": "string",
          "description": "The data product ID"
        },
        "dataProductName": {
          "type": "string",
          "description": "The full name of the data product"
        }
      },
      "type": "object",
      "required": [
        "aspectsApplied",
        "dataProductId",
        "dataProductName"
      ],
      "inputProperties": {
        "readerGroup": {
          "type": "string",
          "description": "Google Group ID for reader access (e.g., 'data-product-readers@example.com')"
        },
        "additionalAspects": {
          "type": "object",
          "additionalProperties": {
            "$ref": "pulumi.json#/Any",
            "plain": true
          },
          "description": "Additional custom aspects"
        },
        "alertEmail": {
          "type": "string",
          "description": "Email address for alerts"
        },
        "availabilityTarget": {
          "type": "string",
          "description": "Availability target percentage"
        },
        "bigqueryDatasets": {
          "type": "array",
          "items": {
            "type": "string",
            "plain": true
          },
          "description": "List of BigQuery dataset IDs to attach"
        },
        "businessDomain": {
          "type": "string",
          "description": "Business domain (e.g., Finance, Marketing)"
        },
        "businessOwner": {
          "type": "string",
          "description": "Business owner email address"
        },
        "businessPurpose": {
          "type": "string",
          "description": "Business purpose statement"
        },
        "changelog": {
          "type": "string",
          "description": "Changelog description"
        },
        "complianceFrameworks": {
          "type": "array",
          "items": {
            "type": "string",
            "plain": true
          },
          "description": "Compliance frameworks (e.g., GDPR, SOX, PIPEDA)"
        },
        "containsPii": {
          "type": "boolean",
          "description": "Whether data contains PII"
        },
        "costCenter": {
          "type": "string",
          "description": "Cost center identifier"
        },
        "dataClassification": {
          "type": "string",
          "description": "Classification level: public, internal, confidential, or restricted"
        },
        "dataProductId": {
          "type": "string",
          "description": "Unique identifier for the data product"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the data product"
        },
        "displayName": {
          "type": "string",
          "description": "Human-readable name for the data product"
        },
        "downstreamDataProducts": {
          "type": "array",
          "items": {
            "type": "string",
            "plain": true
          },
          "description": "List of downstream data product IDs"
        },
        "enableCostTracking": {
          "type": "boolean",
          "description": "Enable cost tracking labels"
        },
        "enableDataQualityScans": {
          "type": "boolean",
          "description": "Enable data quality scans"
        },
        "enableMonitoring": {
          "type": "boolean",
          "description": "Enable monitoring and alerting"
        },
        "gcsBuckets": {
          "type": "array",
          "items": {
            "type": "string",
            "plain": true
          },
          "description": "List of GCS bucket names to attach"
        },
        "glossaryTerms": {
          "type": "array",
          "items": {
            "type": "string",
            "plain": true
          },
          "description": "List of glossary terms"
        },
        "location": {
          "type": "string",
          "description": "GCP location/region"
        },
        "ownerEmails": {
          "type": "array",
          "items": {
            "type": "string",
            "plain": true
          },
          "description": "List of owner email addresses (defaults to [businessOwner, technicalOwner] if not provided)"
        },
        "preApprovedServiceAccounts": {
          "type": "array",
          "items": {
            "type": "string",
            "plain": true
          },
          "description": "List of pre-approved service account emails"
        },
        "project": {
          "type": "string",
          "description": "GCP project ID"
        },
        "projectNumber": {
          "type": "string",
          "description": "GCP project number (e.g. 123456789012)"
        },
        "qualityRules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": {
              "$ref": "pulumi.json#/Any",
              "plain": true
            },
            "plain": true
          },
          "description": "Data quality rules configuration"
        },
        "qualityScanSchedule": {
          "type": "string",
          "description": "Cron schedule for quality scans"
        },
        "dataQualityAlertEmail": {
          "type": "string",
          "description": "Email or distribution list for data quality alerts (if not set, uses alertEmail; alerts auto-enabled if email present)"
        },
        "qualityScoreThreshold": {
          "type": "number",
          "description": "Quality score threshold for alerts (0.0-1.0, default: 0.8 = 80%)"
        },
        "enableDataProfiling": {
          "type": "boolean",
          "description": "Enable data profiling for automatic column-level statistics (nulls, distinct counts, min/max)"
        },
        "profilingSamplingPercent": {
          "type": "number",
          "description": "Sampling percentage for profiling (1-100, default: 100)"
        },
        "useCloudSchedulerForScans": {
          "type": "boolean",
          "description": "Use Cloud Scheduler to trigger quality scans (default: true)"
        },
        "schedulerTimeZone": {
          "type": "string",
          "description": "Timezone for Cloud Scheduler (default: America/Toronto)"
        },
        "lakeName": {
          "type": "string",
          "description": "Dataplex lake name"
        },
        "zoneName": {
          "type": "string",
          "description": "Dataplex zone name"
        },
        "retentionJustification": {
          "type": "string",
          "description": "Justification for data retention period"
        },
        "retentionYears": {
          "type": "integer",
          "description": "Data retention period in years"
        },
        "slaTier": {
          "type": "string",
          "description": "SLA tier: critical, standard, or low"
        },
        "supportHours": {
          "type": "string",
          "description": "Support hours description"
        },
        "tags": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "plain": true
          },
          "description": "Additional resource tags"
        },
        "technicalContact": {
          "type": "string",
          "description": "Technical contact email address"
        },
        "technicalOwner": {
          "type": "string",
          "description": "Technical owner email address"
        },
        "transformationJobs": {
          "type": "array",
          "items": {
            "type": "string",
            "plain": true
          },
          "description": "List of transformation job IDs"
        },
        "upstreamDataProducts": {
          "type": "array",
          "items": {
            "type": "string",
            "plain": true
          },
          "description": "List of upstream data product IDs"
        },
        "version": {
          "type": "string",
          "description": "Version number"
        }
      },
      "requiredInputs": [
        "businessDomain",
        "businessOwner",
        "businessPurpose",
        "dataClassification",
        "dataProductId",
        "description",
        "displayName",
        "location",
        "project",
        "projectNumber",
        "retentionJustification",
        "technicalContact",
        "technicalOwner"
      ],
      "isComponent": true
    },
    "dataproducts:index:SimpleTestComponent": {
      "description": "Simple component that doesn't create any resources - just for testing",
      "properties": {
        "message": {
          "type": "string",
          "description": "The test message output"
        }
      },
      "type": "object",
      "required": [
        "message"
      ],
      "inputProperties": {
        "message": {
          "type": "string",
          "description": "The test message to output"
        }
      },
      "requiredInputs": [
        "message"
      ],
      "isComponent": true
    }
  }
}
